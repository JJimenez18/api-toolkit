  "scripts": {
    "eslint": "eslint . --ext .js,.ts",
    "clean": "del ./build",
    "test": "jest --runInBand --detectOpenHandles",
    "build": "tsc",
    "start": "npm run build && node -r dotenv/config build/index.js",
    "pub": "npm version patch && npm run build && npm publish",
    "git:pub": "git add . && git commit -m \"Updates\" && npm version patch && npm run build && npm publish",
    "com": "npm run build && git add . && git commit -m \"Updates\"",
    "com:pub:beta": "npm run com && npm version patch && npm publish"
  },
