{
  "name": "@chtalent/api-toolkit",
  "version": "1.0.0",
  "description": "Dependencia comun para servicios apificados construidos con express",
  "keywords": [],
  "author": {
    "name": "JJimenez",
    "email": "1074316@onuriscp.com.mx"
  },
  "license": "ISC",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build/**/*"
  ],
  "scripts": {
    "eslint": "eslint . --ext .js,.ts",
    "clean": "del ./build",
    "test": "jest --runInBand --detectOpenHandles",
    "build": "tsc",
    "tgz": "npm run build && npm pack",
    "start": "npm run build && node -r dotenv/config build/index.js",
    "pub": "npm version patch && npm run build && npm publish",
    "git:pub": "git add . && git commit -m \"Updates\" && npm version patch && npm run build && npm publish",
    "com": "npm run build && git add . && git commit -m \"Updates\"",
    "com:pub:beta": "npm run com && npm version patch && npm publish"
  },
  "devDependencies": {
    "@babel/preset-env": "7.24.0",
    "@babel/preset-typescript": "7.23.3",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/express-fileupload": "1.5.0",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "^25.2.3",
    "@types/node-telegram-bot-api": "0.64.6",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "5.59.6",
    "@typescript-eslint/parser": "5.59.6",
    "babel-jest": "29.7.0",
    "del-cli": "5.1.0",
    "dotenv": "16.4.5",
    "eslint": "8.57.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.29.1",
    "express": "4.18.2",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "typescript": "5.0.4"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.496.0",
    "@aws-sdk/client-ssm": "3.496.0",
    "@types/node-rsa": "1.1.4",
    "@types/xml2js": "0.4.14",
    "axios": "0.21.4",
    "cors": "2.8.5",
    "express-async-errors": "3.1.1",
    "express-fileupload": "1.4.3",
    "fast-safe-stringify": "2.1.1",
    "jsonwebtoken": "9.0.2",
    "logform": "2.6.0",
    "maketype": "2.0.1",
    "mongoose": "6.13.0",
    "mysql2": "3.9.2",
    "node-rsa": "1.1.1",
    "node-telegram-bot-api": "0.65.1",
